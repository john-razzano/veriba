APP_NAME=Veriba Backend
DEBUG=true
VERSION=0.1.0
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BASE_API_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
PATIENT_PORTAL_BASE_URL=http://localhost:3000/upload
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/veriba
REDIS_URL=redis://redis:6379/0
PUBLIC_STORAGE_BASE_URL=http://localhost:9000/veriba
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=veriba
MINIO_SECURE=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@veriba.agence.studio
GOOGLE_IOS_CLIENT_ID=
APPLE_BUNDLE_ID=com.jrazzano.proveagence
WIDGET_RATE_LIMIT=100/minute
PATIENT_RATE_LIMIT=10/minute

POSTGRES_DB=veriba
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
